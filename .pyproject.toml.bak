[project]
name = "plain-js-demo-app"
version = "0.1.0"
description = "Gemini Live API - Vanilla JS Example"
dependencies = [
    "aiohttp>=3.8.0",
    "google-genai",
    "python-dotenv",
    "fastapi",
    "uvicorn",
    "pinecone-client",
    "pydantic",
    "aiofiles"
]

[tool.uv]
managed = true
